# App
APP_NAME=AI Email Automation Agent
APP_ENVIRONMENT=development
APP_API_V1_PREFIX=/api/v1
APP_LOG_LEVEL=INFO
APP_LOG_JSON=true

# Database
APP_DATABASE_URL=sqlite:///./app.db

# AI runtime (Phase 2)
APP_AI_PROVIDER=ollama
APP_OLLAMA_MODEL=qwen2.5:7b
APP_OLLAMA_BASE_URL=http://127.0.0.1:11434
APP_OLLAMA_TIMEOUT_SECONDS=20

# Optional: email/calendar integrations (Phase 2+)
APP_IMAP_HOST=
APP_IMAP_PORT=993
APP_IMAP_USERNAME=
APP_IMAP_PASSWORD=
APP_IMAP_PASSWORD_FILE=
APP_IMAP_DEFAULT_MAILBOX=INBOX
APP_IMAP_USE_SSL=true
APP_IMAP_PULL_INTERVAL_MINUTES=5
APP_IMAP_PULL_UNSEEN_ONLY=true
APP_IMAP_PULL_LIMIT=25
APP_SMTP_HOST=
APP_SMTP_PORT=587
APP_SMTP_USERNAME=
APP_SMTP_PASSWORD=
APP_SMTP_PASSWORD_FILE=
APP_SMTP_USE_TLS=true
APP_SMTP_FROM_EMAIL=
APP_GOOGLE_CLIENT_ID=
APP_GOOGLE_CLIENT_SECRET=
APP_GOOGLE_CLIENT_SECRET_FILE=
APP_GOOGLE_REDIRECT_URI=
APP_CREDENTIALS_ENCRYPTION_KEY=
APP_CREDENTIALS_ENCRYPTION_KEY_FILE=
APP_GOOGLE_OAUTH_AUTHORIZE_URL=https://accounts.google.com/o/oauth2/v2/auth
APP_GOOGLE_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
APP_GOOGLE_OAUTH_STATE_TTL_SECONDS=600
APP_GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar.events
APP_SECURITY_BASIC_AUTH_ENABLED=false
APP_SECURITY_BASIC_AUTH_USERNAME=
APP_SECURITY_BASIC_AUTH_PASSWORD=
APP_SECURITY_BASIC_AUTH_PASSWORD_FILE=

# Alerts + Observability
APP_ALERTS_ENABLED=false
APP_ALERTS_WEBHOOK_URL=
APP_ALERTS_WEBHOOK_TIMEOUT_SECONDS=8
APP_ALERTS_EMAIL_TO=
APP_ALERTS_MIN_INTERVAL_SECONDS=300

# Scheduler
APP_SCHEDULER_ENABLED=true
APP_SCHEDULER_TIMEZONE=UTC
APP_CLASSIFY_INTERVAL_MINUTES=2
APP_CLASSIFY_BATCH_SIZE=25
APP_ACTION_PLAN_INTERVAL_MINUTES=2
APP_ACTION_PLAN_BATCH_SIZE=25
APP_ACTION_EXECUTION_INTERVAL_MINUTES=1
APP_ACTION_EXECUTION_BATCH_SIZE=25

# Action handlers
APP_ACTION_INVOICE_ACCOUNTING_EMAIL=
APP_ACTION_MEETING_DEFAULT_DURATION_MINUTES=30
APP_ACTION_CALENDAR_TIMEZONE=UTC
APP_ACTION_MAX_ATTEMPTS=3
APP_ACTION_RETRY_BASE_SECONDS=60
APP_ACTION_RETRY_MAX_SECONDS=3600

# Google Calendar (Phase 5)
APP_GOOGLE_CALENDAR_ENABLED=false
APP_GOOGLE_CALENDAR_ACCESS_TOKEN=
APP_GOOGLE_CALENDAR_ACCESS_TOKEN_FILE=
APP_GOOGLE_CALENDAR_REFRESH_TOKEN=
APP_GOOGLE_CALENDAR_REFRESH_TOKEN_FILE=
APP_GOOGLE_CALENDAR_CALENDAR_ID=primary
APP_GOOGLE_CALENDAR_BASE_URL=https://www.googleapis.com/calendar/v3
